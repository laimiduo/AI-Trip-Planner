### LLM — DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.5

### Amap / Gaode
AMAP_API_KEY=

### Redis (optional — 不配置则使用 NullCache 降级)
REDIS_URL=
ENABLE_CACHE=true

### PostgreSQL (optional — 不配置则跳过 DB 功能)
DATABASE_URL=
ENABLE_DB=true

### ARQ (optional)
ENABLE_ARQ=true

### Server
HOST=127.0.0.1
PORT=8000
DEBUG=false
